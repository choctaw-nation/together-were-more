{
	"name": "choctaw-nation/together-were-more",
	"description": "the custom WP theme for the TWM site",
	"type": "project",
	"version": "3.0.0",
	"autoload": {
		"classmap": [
			"inc/"
		]
	},
	"extra": {
		"installer-paths": {
			"vendor/{$name}/": [
				"wpengine/advanced-custom-fields"
			]
		}
	},
	"repositories": [
		{
			"type": "composer",
			"url": "https://wpackagist.org",
			"only": [
				"wpackagist-plugin/*",
				"wpackagist-theme/*"
			]
		},
		{
			"type": "composer",
			"url": "https://composer.advancedcustomfields.com"
		}
	],
	"scripts": {
		"phpcs": "phpcs . inc/ --extensions=php --ignore=dist/",
		"phpcbf": "phpcbf . inc/ --extensions=php --ignore=dist/",
		"test": "phpunit",
		"install-tests": [
			"chmod +x bin/local-mysql-socket.sh",
			"bash -lc 'SOCK=\"$(bin/local-mysql-socket.sh)\"; bash -x bin/install-wp-tests.sh wordpress_test root root \"$SOCK\" latest'"
		]
	},
	"config": {
		"allow-plugins": {
			"composer/installers": true,
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	},
	"require-dev": {
		"doctrine/instantiator": "^1",
		"phpunit/phpunit": "^9",
		"wp-coding-standards/wpcs": "*",
		"wpengine/advanced-custom-fields": "*",
		"yoast/phpunit-polyfills": "^4.0",
		"php-stubs/acf-pro-stubs": "*"
	}
}
