{
	"name": "together-were-more",
	"version": "3.0.0",
	"description": "Custom WP theme for Together We're More site",
	"browserslist": [
		"extends @wordpress/browserslist-config"
	],
	"prettier": "@wordpress/prettier-config",
	"scripts": {
		"build": "wp-scripts build --blocks-manifest --webpack-copy-php --experimental-modules --config=webpack.config.mjs --source-path=wp-content/themes/together-were-more/src/ --output-path=wp-content/themes/together-were-more/dist/",
		"check-engines": "wp-scripts check-engines",
		"lint:css": "npx stylelint '**/*.scss' '**/*.css' --fix",
		"lint:js": "npx eslint --fix",
		"packages-update": "wp-scripts packages-update",
		"start": "wp-scripts start --blocks-manifest --webpack-copy-php --experimental-modules --config=webpack.config.mjs --source-path=wp-content/themes/together-were-more/src/ --output-path=wp-content/themes/together-were-more/dist/",
		"test:dev": "echo 'Test not implemented yet' && exit 0",
		"test:stg": "echo 'Test not implemented yet' && exit 0"
	},
	"author": "Choctaw Nation of Oklahoma",
	"license": "GPL-3.0-or-later",
	"dependencies": {
		"@choctawnationofoklahoma/lite-vimeo": "^1.3.1",
		"@choctawnationofoklahoma/wp-flex-reverse-toggle": "^1.1.1",
		"aos": "^2.3.4",
		"bootstrap": "^5.3.8",
		"swiper": "^12.2.0"
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@wordpress/block-editor": "^15.21.1",
		"@wordpress/blocks": "^15.21.1",
		"@wordpress/components": "^35.0.1",
		"@wordpress/compose": "^8.1.1",
		"@wordpress/core-data": "^7.48.1",
		"@wordpress/data": "^10.48.1",
		"@wordpress/editor": "^14.48.1",
		"@wordpress/element": "^8.0.1",
		"@wordpress/eslint-plugin": "^25.4.1",
		"@wordpress/hooks": "^4.48.1",
		"@wordpress/prettier-config": "^4.48.1",
		"@wordpress/primitives": "^4.48.1",
		"@wordpress/scripts": "^32.4.1",
		"eslint": "^9",
		"globals": "^17.6.0",
		"prettier": "npm:wp-prettier@^3.0.3",
		"stylelint": "^17.13.0",
		"stylelint-config-standard-scss": "^17.0.0",
		"stylelint-scss": "^7.2.0",
		"webpack-remove-empty-scripts": "^1.1.1"
	},
	"allowScripts": {
		"@parcel/watcher@2.5.6": true,
		"core-js@3.49.0": true,
		"core-js-pure@3.49.0": true,
		"unrs-resolver@1.12.2": true,
		"fsevents@2.3.3": true,
		"fsevents@2.3.2": true
	}
}
